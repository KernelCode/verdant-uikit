{
  "$schema": "https://tr.designtokens.org/format/tokens.schema.json",
  "$description": "Verdant design tokens (W3C DTCG). Premium furniture storefront — emerald green brand, warm orange accent, cream canvas, near-black actions, Plus Jakarta Sans + Tajawal (Arabic), RTL-ready.",
  "color": {
    "$type": "color",
    "brand": {
      "50": { "$value": "#eef4ee" },
      "100": { "$value": "#d6e6d8" },
      "200": { "$value": "#aeceb1" },
      "300": { "$value": "#7fae85" },
      "400": { "$value": "#4d8a59" },
      "500": { "$value": "#2e7d46" },
      "600": { "$value": "#1f5c32" },
      "700": { "$value": "#17451f" },
      "800": { "$value": "#102f17" },
      "900": { "$value": "#0c2413" }
    },
    "accent": {
      "50": { "$value": "#fbf0e6" },
      "100": { "$value": "#f6dcc2" },
      "400": { "$value": "#e08a3c" },
      "DEFAULT": { "$value": "#cf6a1a" }
    },
    "light": {
      "background": { "$value": "#f4f3ee" },
      "foreground": { "$value": "#181b17" },
      "card": { "$value": "#ffffff" },
      "muted": { "$value": "#edebe3" },
      "muted-foreground": { "$value": "#6e7269" },
      "border": { "$value": "#e6e4db" },
      "primary": { "$value": "#181b17" },
      "primary-foreground": { "$value": "#ffffff" },
      "brand": { "$value": "#1f5c32" },
      "ink": { "$value": "#17271b" },
      "ink-foreground": { "$value": "#eef1e9" },
      "stage": { "$value": "#f0efe8" },
      "mark": { "$value": "#c7e0b4" },
      "discount": { "$value": "#1f5c32" }
    },
    "dark": {
      "background": { "$value": "#0e110f" },
      "foreground": { "$value": "#eef1e9" },
      "card": { "$value": "#161a16" },
      "muted": { "$value": "#1c211c" },
      "border": { "$value": "#262b25" },
      "primary": { "$value": "#eef1e9" },
      "brand": { "$value": "#3fa063" },
      "ink": { "$value": "#0a0f0b" },
      "accent": { "$value": "#e0843a" }
    }
  },
  "font": {
    "$type": "fontFamily",
    "display": { "$value": ["Plus Jakarta Sans", "Tajawal", "sans-serif"] },
    "sans": { "$value": ["Plus Jakarta Sans", "Tajawal", "sans-serif"] },
    "mono": { "$value": ["Space Mono", "monospace"] }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "0.625rem" },
    "DEFAULT": { "$value": "1rem" },
    "lg": { "$value": "1.5rem" },
    "xl": { "$value": "2rem" },
    "2xl": { "$value": "2.5rem" }
  }
}
